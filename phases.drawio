                </mxCell>
                <mxCell id="18" value="In this step, the PCs assigned to employees will be identified and managed to ensure proper tracking, allocation, and system visibility." style="text;strokeColor=#82b366;align=center;fillColor=#d5e8d4;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
